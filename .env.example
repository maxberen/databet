# Copiar a .env y completar. Nunca commitear .env real.

# --- Base de datos (MySQL 8) ---
# Formato: mysql+pymysql://USER:PASSWORD@HOST:PORT/DBNAME
# El charset utf8mb4 lo agrega config/database.py automáticamente.
DATABASE_URL=mysql+pymysql://databet:changeme@127.0.0.1:3306/betting_system

# --- The Odds API (fuente piloto Fase 1) ---
# Registrarse gratis en https://the-odds-api.com  (free tier: 500 req/mes)
ODDS_API_KEY=

# --- Cifrado de credenciales en capa app (Fernet) ---
# Generar con:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
